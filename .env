# CodeIgniter 4 Environment Configuration
CI_ENVIRONMENT = development

# App Settings
app.baseURL = 'http://localhost:9001/'

# Database Settings
database.default.hostname = 'mysql'
database.default.username = 'root'
database.default.password = 'root_password'
database.default.database = 'db_Chege OS'
database.default.DBDriver = 'MySQLi'
database.default.port = 3306
database.default.socket = ''


#--------------------------------------------------------------------
# EMAIL CONFIGURATION
#--------------------------------------------------------------------
# This toggle controls whether to send an email on user registration.
AUTH_SEND_EMAIL_ON_REGISTER=false

email.fromEmail = "noreply@example.com"
email.fromName = "System Admin"
email.protocol = "smtp"
email.SMTPHost = "smtp.mailtrap.io"
email.SMTPUser = "dummy_user"
email.SMTPPass = "dummy_pass"
email.SMTPPort = 2525
email.SMTPCrypto = "tls"
